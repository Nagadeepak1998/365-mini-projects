{
  "apiVersion": "v1",
  "kind": "List",
  "items": [
    {
      "apiVersion": "apps/v1",
      "kind": "Deployment",
      "metadata": {
        "namespace": "prod",
        "name": "billing-api"
      },
      "spec": {
        "replicas": 3,
        "strategy": {
          "type": "RollingUpdate",
          "rollingUpdate": {
            "maxUnavailable": 1
          }
        },
        "template": {
          "metadata": {
            "labels": {
              "app": "billing-api"
            }
          },
          "spec": {
            "containers": [
              {
                "name": "api",
                "image": "example.com/billing:v3",
                "readinessProbe": {
                  "httpGet": {
                    "path": "/ready",
                    "port": 8080
                  }
                }
              }
            ]
          }
        }
      }
    },
    {
      "apiVersion": "policy/v1",
      "kind": "PodDisruptionBudget",
      "metadata": {
        "namespace": "prod",
        "name": "billing-api-pdb"
      },
      "spec": {
        "minAvailable": 2,
        "selector": {
          "matchLabels": {
            "app": "billing-api"
          }
        }
      }
    }
  ]
}
