{
  "routes": [
    {
      "route_key": "GET /payments/{paymentId}",
      "environment": "prod",
      "owner": "payments-platform",
      "public": true,
      "critical": true,
      "auth_type": "jwt",
      "throttling": {
        "enabled": true,
        "rate_limit_per_second": 200,
        "burst_limit": 400
      },
      "access_logs": {
        "enabled": true,
        "retention_days": "30"
      },
      "integration": {
        "type": "lambda",
        "timeout_seconds": 15,
        "lambda_alias": "live",
        "request_validation": true
      },
      "alarms": [
        {
          "metric_name": "5XXError",
          "threshold": 5,
          "runbook": "https://runbooks.example/api/payments"
        },
        {
          "metric_name": "Latency",
          "threshold": 1000,
          "runbook": "https://runbooks.example/api/payments"
        }
      ],
      "rollback_note": "Shift the Lambda alias back to the previous version.",
      "canary": {
        "enabled": true,
        "percent": 10
      }
    }
  ]
}
